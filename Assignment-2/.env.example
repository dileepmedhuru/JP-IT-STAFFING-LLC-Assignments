# ─────────────────────────────────────────────────────────────
# Singing Bowl Export Desk – Environment Variables
# Copy this file to .env and fill in your real credentials
# ─────────────────────────────────────────────────────────────

# SerpApi key (get one free at https://serpapi.com)
# Leave blank to run in DEMO MODE (fake results, no real scraping)
SERPAPI_KEY=

# Gmail account that sends the emails
GMAIL_USER=handcraftedsingingbowl@gmail.com

# Gmail App Password (NOT your real password)
# Go to: Google Account → Security → 2FA → App Passwords → Generate
# Leave blank to simulate sending (email is logged but not dispatched)
GMAIL_APP_PASSWORD=

# WhatsApp number shown in email templates
WHATSAPP_NUMBER=+977-9800000000
